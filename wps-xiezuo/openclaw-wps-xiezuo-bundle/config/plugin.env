# openclaw-wps-xiezuo 配置文件
# 使用方式：
# 1) 将 APP_ID / APP_SECRET 改成你自己的值
# 2) 按需调整 ACCOUNT_ID / AGENT_ID / DM_POLICY
# 3) 保存后执行: bash scripts/install.sh
#
# 【必填】WPS 开放平台应用 ID
APP_ID=
#
# 【必填】WPS 开放平台应用密钥
# 当 DM_POLICY=disabled 时可留空
APP_SECRET=
#
# 账号 ID（channels.wps-xiezuo.accounts.<ACCOUNT_ID>）
ACCOUNT_ID=default
#
# 绑定的 agentId（会写入 bindings）
AGENT_ID=main
#
# DM 策略：disabled/open/pairing/allowlist
DM_POLICY=pairing
#
# 群策略：open/allowlist
GROUP_POLICY=open
#
# WPS API 基础地址
BASE_URL=https://openapi.wps.cn
#
# 会话隔离粒度（文档推荐按账号+channel+用户）
SESSION_DM_SCOPE=per-account-channel-peer
#
# SDK 长连接开关：1=启用，0=禁用
SDK_ENABLED=1
#
# SDK 日志级别：debug/info/warn/error
SDK_LOG_LEVEL=info
#
# SDK 连接超时（毫秒）
SDK_CONNECT_TIMEOUT_MS=120000
#
# SDK 长连接 endpoint（默认留空使用 open-event-sdk 默认值）
SDK_ENDPOINT=
#
# allowlist 用户（逗号分隔）；当 DM_POLICY=allowlist 时生效
ALLOW_FROM=
#
# 高级：完整覆盖 accounts（JSON object）
WPS_ACCOUNTS_JSON=
#
# 高级：完整覆盖 bindings（JSON array）
WPS_BINDINGS_JSON=
#
# 高级：可选写入 agents（JSON object）
WPS_AGENTS_JSON=
#
